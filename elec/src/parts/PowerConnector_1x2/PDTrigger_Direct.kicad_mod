(footprint "PDTrigger_Direct"
	(version 20241229)
	(generator "hand-crafted")
	(layer "F.Cu")
	(descr "USB-C PD trigger board, 9x14mm + 4mm USB-C overhang. Mount back-down on PCB. USB-C hangs off PCB edge. + and - output pads are on the board back at the non-USB-C end, aligned to F.Cu SMD pads below. Configure for 12V by bridging appropriate solder pads on front before mounting. Pad positions ESTIMATED from product images.")
	(tags "PD trigger USB-C 12V power direct mount")
	(property "Reference" "REF**"
		(at 0 -10.0 0)
		(layer "F.SilkS")
		(effects (font (size 1 1) (thickness 0.15)))
	)
	(property "Value" "PDTrigger_Direct"
		(at 0 10.0 0)
		(layer "F.Fab")
		(effects (font (size 1 1) (thickness 0.15)))
	)
	(attr smd)

	(fp_rect
		(start -4.5 -7.0)
		(end 4.5 7.0)
		(stroke (width 0.05) (type solid))
		(fill no)
		(layer "F.CrtYd")
	)
	(fp_rect
		(start -4.5 -7.0)
		(end 4.5 7.0)
		(stroke (width 0.12) (type solid))
		(fill no)
		(layer "F.Fab")
	)

	(fp_rect
		(start -4.5 -11.0)
		(end 4.5 -7.0)
		(stroke (width 0.05) (type solid))
		(fill no)
		(layer "F.CrtYd")
	)
	(fp_rect
		(start -4.5 -11.0)
		(end 4.5 -7.0)
		(stroke (width 0.05) (type solid))
		(fill no)
		(layer "F.Fab")
	)

	(fp_text user "USB-C"
		(at 0 -9.0 0)
		(layer "F.SilkS")
		(effects (font (size 0.6 0.6) (thickness 0.1)))
	)
	(fp_text user "+"
		(at -3.0 4.5 0)
		(layer "F.SilkS")
		(effects (font (size 0.8 0.8) (thickness 0.12)))
	)
	(fp_text user "-"
		(at 3.0 4.5 0)
		(layer "F.SilkS")
		(effects (font (size 0.8 0.8) (thickness 0.12)))
	)
	(fp_text user "CFG"
		(at 0 -5.0 0)
		(layer "F.Fab")
		(effects (font (size 0.6 0.6) (thickness 0.1)))
	)
	(fp_text user "configure 12V before mounting"
		(at 0 8.5 0)
		(layer "F.Fab")
		(effects (font (size 0.5 0.5) (thickness 0.08)))
	)

	(pad "1" smd rect
		(at -3.0 6.0)
		(size 1.8 1.8)
		(layers "F.Cu" "F.Paste" "F.Mask")
	)
	(pad "2" smd rect
		(at 3.0 6.0)
		(size 1.8 1.8)
		(layers "F.Cu" "F.Paste" "F.Mask")
	)

	(embedded_fonts no)
)
